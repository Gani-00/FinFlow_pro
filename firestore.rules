rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.amount is number &&
             data.category is string && data.category.size() <= 50 &&
             data.type in ['income', 'expense'] &&
             data.date is timestamp;
    }

    function isValidBudget(data) {
      return data.userId == request.auth.uid &&
             data.category is string && data.category.size() <= 50 &&
             data.limit is number && data.limit >= 0;
    }

    function isValidRecurring(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() <= 50 &&
             data.dayOfMonth is number &&
             data.dayOfMonth >= 1 && data.dayOfMonth <= 31 &&
             data.createdAt is timestamp;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.target is number && data.target >= 0 &&
             data.current is number && data.current >= 0 &&
             data.icon is string && data.icon.size() <= 50 &&
             data.color is string && data.color.size() <= 50;
    }

    function isValidPartner(data) {
      return (data.senderId == request.auth.uid || data.email == request.auth.token.email) &&
             data.senderName is string && data.senderName.size() > 0 && data.senderName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.status in ['pending', 'accepted'] &&
             data.createdAt is timestamp;
    }

    // Collections
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name']);
    }

    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(transactionId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isSignedIn() && isValidId(transactionId) && resource.data.userId == request.auth.uid && 
                    isValidTransaction(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'amount', 'category', 'type', 'date', 'note']);
      allow delete: if isSignedIn() && isValidId(transactionId) && resource.data.userId == request.auth.uid;
    }

    match /budgets/{budgetId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(budgetId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(budgetId) && isValidBudget(incoming());
      allow update: if isSignedIn() && isValidId(budgetId) && resource.data.userId == request.auth.uid && 
                    isValidBudget(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['limit']);
      allow delete: if isSignedIn() && isValidId(budgetId) && resource.data.userId == request.auth.uid;
    }

    match /recurring/{billId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(billId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(billId) && isValidRecurring(incoming());
      allow update: if isSignedIn() && isValidId(billId) && resource.data.userId == request.auth.uid && 
                    isValidRecurring(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'amount', 'category', 'dayOfMonth']);
      allow delete: if isSignedIn() && isValidId(billId) && resource.data.userId == request.auth.uid;
    }

    match /goals/{goalId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(goalId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(goalId) && isValidGoal(incoming());
      allow update: if isSignedIn() && isValidId(goalId) && resource.data.userId == request.auth.uid && 
                    isValidGoal(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'target', 'current', 'icon', 'color']);
      allow delete: if isSignedIn() && isValidId(goalId) && resource.data.userId == request.auth.uid;
    }

    match /partners/{partnerId} {
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.email == request.auth.token.email);
      allow get: if isSignedIn() && isValidId(partnerId) && (resource.data.senderId == request.auth.uid || resource.data.email == request.auth.token.email);
      allow create: if isSignedIn() && isValidId(partnerId) && incoming().senderId == request.auth.uid && isValidPartner(incoming()) && incoming().status == 'pending';
      allow update: if isSignedIn() && isValidId(partnerId) && (
        (existing().email == request.auth.token.email && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'receiverId']) && incoming().status == 'accepted' && incoming().receiverId == request.auth.uid) ||
        (existing().senderId == request.auth.uid && isValidPartner(incoming()))
      );
      allow delete: if isSignedIn() && isValidId(partnerId) && (resource.data.senderId == request.auth.uid || resource.data.email == request.auth.token.email);
    }
  }
}
